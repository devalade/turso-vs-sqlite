{
  "name": "turso-vs-sqlite",
  "version": "1.0.0",
  "description": "Benchmark: Turso (Rust SQLite) vs better-sqlite3 vs node:sqlite",
  "scripts": {
    "bench": "node src/bench.js",
    "bench:json": "node src/bench.js --json results.json",
    "concurrent": "node src/concurrent.js",
    "concurrent:json": "node src/concurrent.js --json results-concurrent.json",
    "bench:all": "node src/bench.js && node src/concurrent.js",
